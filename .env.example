# ──────────────────────────────────────────────────────────────────────────
# Variables d'environnement — JJK Arcade
# ──────────────────────────────────────────────────────────────────────────
# Copie ce fichier en `.env` (non commité) et renseigne les valeurs.

# Base de données Neon (Postgres) — requise pour l'auth et le leaderboard.
# Crée un projet sur https://neon.tech puis copie la connection string ici.
# Applique le schéma avec :  npm run db:push   (puis npm run db:generate)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Comptes promus automatiquement en rôle ADMIN (emails séparés par des virgules).
# Un utilisateur qui s'inscrit / se connecte avec un de ces emails devient ADMIN
# et accède à /admin (édition du roster).
ADMIN_EMAILS="admin@example.com"


# ──────────────────────────────────────────────────────────────────────────
# Pusher Channels — requis pour le mode multijoueur en temps réel.
# Crée une app gratuite sur https://pusher.com (Channels) puis copie les clés.
# APP_ID et SECRET restent côté serveur ; KEY et CLUSTER sont exposés au client
# (préfixe NEXT_PUBLIC_). Sans ces variables, seul le mode multijoueur est
# désactivé — le reste de l'app fonctionne normalement.
PUSHER_APP_ID="123456"
PUSHER_SECRET="your-pusher-secret"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# ──────────────────────────────────────────────────────────────────────────
# API booru — récupération auto des images de perso (bouton « OUAIS » dans /admin).
# URL de base de l'endpoint posts, SANS &tags=... (ajouté automatiquement).
# Optionnel : sans cette variable, le bouton « OUAIS » renvoie une erreur.
BOORU_API_BASE="https://example.booru/index.php?page=dapi&s=post&q=index"
# Clés d'API si le booru les exige (rule34.xxx les rend obligatoires).
BOORU_API_KEY=""
BOORU_USER_ID=""
# Tag de série ajouté à chaque requête (optionnel, défaut : jujutsu_kaisen).
BOORU_SERIES_TAG="jujutsu_kaisen"
# Délai (ms) entre deux appels API pour respecter la limite par seconde (déf. 300).
BOORU_REQUEST_DELAY_MS="300"
