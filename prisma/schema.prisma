// Schéma Prisma — JJK Arcade (Neon Postgres).
//
// Workflow : pas de migrations, on synchronise le schéma avec la base via
//   npx prisma db push        (applique le schéma à Neon)
//   npx prisma generate       (régénère le client typé)
//
// DATABASE_URL est défini dans .env (voir .env.example).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Rôle d'un utilisateur. PLAYER par défaut ; ADMIN donne accès à /admin.
/// VIP : joueur privilégié — peut rejouer JJKdle un nombre limité de fois par
/// jour (cf. VIP_MAX_REPLAYS), sans accès à l'admin.
enum Role {
  PLAYER
  VIP
  ADMIN
}

/// Compte utilisateur. Le jeu se joue sans compte ; le compte sert au
/// leaderboard (enregistrement des scores) et, pour les ADMIN, à l'édition du roster.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         Role     @default(PLAYER)
  createdAt    DateTime @default(now())

  // ── Customisation profil (ensembles fermés, aucun upload) ──
  bannerKey         String     @default("default") // clé ∈ BANNER_PALETTE (lib/profile/banners.ts)
  avatarCharacterId String?
  avatarCharacter   Character? @relation("UserAvatar", fields: [avatarCharacterId], references: [id], onDelete: SetNull)

  // Titre + cadre équipés (au plus un de chaque, ou aucun). Comme bannerKey, ce
  // sont des CLÉS vers des catalogues définis en code (lib/titles, lib/frames) —
  // source de vérité = code, pas de table. Validés serveur à l'équipement.
  equippedTitleKey String? // clé ∈ TITLES (lib/titles/definitions.ts) ou null
  equippedFrameKey String? // clé ∈ FRAMES (lib/frames/definitions.ts) ou null

  // Mise en page du profil PUBLIC : visibilité (titre, cadre, badges, scores) et
  // ordre des sections de corps (badges/scores). Forme libre validée/normalisée
  // en code (lib/profile/layout.ts). null = layout par défaut (tout affiché).
  profileLayout Json?

  // ── Progression (cache recalculé en fin de partie ; source = scores) ──
  totalXp Int @default(0)
  xpBonus Int @default(0) // ajustement manuel admin (additif, persistant)
  level   Int @default(1)

  // ── Streak quotidien JJKdle (jour de réf. = Europe/Paris, cf. todayKey) ──
  jjkdleStreak       Int     @default(0)
  jjkdleBestStreak   Int     @default(0)
  jjkdleLastPlayedAt String? // clé "YYYY-MM-DD" du dernier daily complété

  sessions     Session[]
  scores       Score[]
  lobbyPlayers LobbyPlayer[]
  draftScores  JujutsuDraftScore[]
  jjkdleScores JjkdleScore[]
  higherLowerScores HigherLowerScore[]
  guessWhoScores GuessWhoScore[]
  badges       UserBadge[]
  titleGrants  UserTitleGrant[]
  frameGrants  UserFrameGrant[]
}

/// Déblocage d'un badge par un utilisateur. La métadonnée du badge (nom,
/// description, icône, règle) vit dans le code (lib/badges/definitions.ts) ;
/// seule la possession est persistée. `badgeKey` réfère une clé de BADGES.
model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeKey   String
  unlockedAt DateTime @default(now())
  /// Id de l'admin ayant octroyé MANUELLEMENT le badge. null = débloqué par règle
  /// dérivée (cf. lib/badges/evaluate). Sert à tracer l'origine, sans changer la
  /// logique : un badge dérivé encore mérité se re-débloque même après retrait.
  grantedBy  String?

  @@unique([userId, badgeKey])
  @@index([userId])
}

/// Octroi MANUEL d'un titre par un admin (cf. §5). Séparé du déblocage dérivé
/// (lib/cosmetics/unlock) pour pouvoir l'accorder/retirer sans toucher aux stats.
/// `titleKey` réfère une clé de TITLES (lib/titles/definitions.ts). Un titre est
/// considéré débloqué si la règle dérivée est vraie OU un grant existe OU admin.
model UserTitleGrant {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titleKey  String
  grantedBy String // id de l'admin ayant octroyé
  grantedAt DateTime @default(now())

  @@unique([userId, titleKey])
  @@index([userId])
}

/// Octroi MANUEL d'un cadre par un admin (cf. §5). Même logique que
/// UserTitleGrant. `frameKey` réfère une clé de FRAMES (lib/frames/definitions.ts).
model UserFrameGrant {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  frameKey  String
  grantedBy String
  grantedAt DateTime @default(now())

  @@unique([userId, frameKey])
  @@index([userId])
}

/// Session d'authentification (token aléatoire stocké en cookie httpOnly).
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Issue d'une partie de Jujutsu Draft.
enum DraftOutcome {
  VICTORY
  DEFEAT
}

// ──────────────────────────────────────────────────────────────────────────
// Attributs JJKdle (jeu de déduction quotidien). Listes fermées = enums.
// Remplis via /admin (non seedés). Colonnes ajoutées au model Character ci-dessous,
// toutes nullable → le builder/battle/ranking ne sont pas impactés.
// ──────────────────────────────────────────────────────────────────────────

/// Race / nature du personnage (JJKdle).
enum JjkRace {
  HUMAN
  CURSED_SPIRIT // fléau
  SHIKIGAMI
  CURSED_CORPSE
  OTHER
}

/// Genre (JJKdle).
enum JjkGender {
  MALE
  FEMALE
  OTHER
}

/// Grade hiérarchique JJK. L'ORDRE DES VALEURS EST SIGNIFIANT (croissant) :
/// il sert à l'indice ↑/↓ (la cible est d'un grade plus haut / plus bas).
enum JjkGrade {
  GRADE_4
  SEMI_GRADE_3
  GRADE_3
  SEMI_GRADE_2
  GRADE_2
  SEMI_GRADE_1
  GRADE_1
  SPECIAL_GRADE
}

/// Affiliation principale (mono-valeur). Étendre si le roster l'exige.
enum JjkAffiliation {
  TOKYO_SCHOOL
  KYOTO_SCHOOL
  CULLING_GAME
  SHIBUYA
  CURSED_SPIRITS_FACTION
  OTHER
}

/// Clan d'origine. NONE = pas de clan (≠ null = attribut non renseigné).
enum JjkClan {
  ZENIN
  KAMO
  GOJO
  NONE
}

/// Arc de première apparition. L'ORDRE DES VALEURS EST SIGNIFIANT (chronologique
/// au sens de l'histoire) : il sert à l'indice ↑/↓ (apparu plus tard / plus tôt).
/// GOJOS_PAST est un flashback : placé ici à l'arc de première apparition à l'écran.
enum JjkArc {
  JJK_0 // Jujutsu Kaisen 0 (préquel) : Yuta, Rika, Maki, Inumaki, Panda, Geto
  FEARSOME_WOMB // Cursed Womb / Prologue : Yuji, Sukuna, école de Tokyo
  VS_MAHITO // Vs Mahito / premiers fléaux
  KYOTO_GOODWILL_EVENT // Échange Tokyo-Kyoto, Hanami
  DEATH_PAINTING // Death Painting / pont Yasohachi : Choso & frères
  GOJOS_PAST // Flashback Gojo & Geto, Riko Amanai, Toji
  SHIBUYA_INCIDENT // Scellement de Gojo, mort de Nanami
  ITADORI_EXTERMINATION // Post-Shibuya / Perfect Preparation
  CULLING_GAME // Colonies, Kashimo, Higuruma, Reggie…
  SHINJUKU_SHOWDOWN // Bataille finale Gojo vs Sukuna
  FINAL // Dénouement après la chute de Sukuna
  MODULO // Jujutsu Kaisen Modulo (récit annexe)
}

/// Meilleur score de Jujutsu Draft d'un utilisateur (un enregistrement par
/// utilisateur — upsert quand un meilleur résultat est obtenu). `globalScore`
/// est le score global caché recalculé côté serveur (anti-triche) ; `draft`
/// est le snapshot des persos choisis par catégorie au moment du record.
model JujutsuDraftScore {
  id            String       @id @default(cuid())
  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  enemiesKilled Int
  globalScore   Int
  outcome       DraftOutcome
  draft         Json
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([enemiesKilled, globalScore])
}

/// Score JJKdle : nombre d'essais d'un utilisateur pour le perso mystère d'un
/// JOUR donné (un enregistrement par couple utilisateur/date). Le classement
/// quotidien se lit en filtrant sur la date du jour (`date` = "YYYY-MM-DD") et
/// se classe par `attempts` croissant (moins d'essais = meilleur). Les entrées
/// des jours passés restent en base mais ne sont plus affichées → reset quotidien.
/// Seules les parties en mode "daily" (perso commun) sont enregistrées ; les
/// parties bonus admin/VIP (perso aléatoire) ne comptent pas.
model JjkdleScore {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  attempts  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([date, attempts])
}

/// Score d'une partie de « JJK Higher/Lower » — une ligne PAR PARTIE terminée
/// (append, pas d'upsert). `score` = nombre de bonnes réponses ; `xpEarned` = XP
/// octroyée pour cette partie (persistée pour l'affichage ; l'XP totale reste
/// agrégée sur User.totalXp via awardExp). Le classement se lit best-par-joueur
/// (DISTINCT ON userId, cf. lib/games/higher-lower/store.ts).
model HigherLowerScore {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int
  xpEarned  Int
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([score])
}

/// État autoritatif d'une partie « Higher/Lower » EN COURS (anti-triche).
/// Éphémère : créée au démarrage, supprimée en fin de partie. `id` = runId
/// référencé par le cookie httpOnly `hl_run`. `userId` nullable → jouable sans
/// compte. `rightCursedEnergy` = valeur cachée du perso de droite, JAMAIS exposée
/// au client tant qu'il n'a pas répondu. `usedIds` = persos déjà apparus (évite la
/// répétition immédiate à droite).
model HigherLowerSession {
  id                String   @id @default(cuid())
  userId            String?
  score             Int      @default(0)
  leftId            String
  leftCursedEnergy  Int
  rightId           String
  rightCursedEnergy Int
  usedIds           String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

/// Partie « Qui est-ce ? » (Guess Who JJK) — état autoritatif d'un 1v1 en cours.
/// Réutilise le lobby/présence Pusher (Lobby via lobbyId). Les DEUX secrets vivent
/// ICI et ne sont JAMAIS sérialisés vers le client tant que la partie est ACTIVE
/// (anti-triche) : chaque joueur ne récupère que le sien via une Server Action
/// authentifiée. La grille (25 IDs) est partagée/identique pour les deux joueurs ;
/// seuls les secrets diffèrent. Les éliminations sont locales/privées (non persistées).
model GuessWhoGame {
  id          String   @id @default(cuid())
  lobbyId     String   @unique
  player1Id   String
  player2Id   String
  gridCharIds String[] // 25 IDs, ordre partagé
  secret1Id   String // secret que player2 doit deviner (= perso secret de player1)
  secret2Id   String // secret que player1 doit deviner (= perso secret de player2)
  currentTurn String // userId dont c'est le tour
  status      String   @default("ACTIVE") // ACTIVE | FINISHED
  winnerId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lobbyId])
}

/// Résultat d'une partie « Qui est-ce ? » — une ligne PAR joueur ET PAR partie
/// terminée (append). `won` = ce joueur a gagné. Le ratio V/D se lit par agrégation.
model GuessWhoScore {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  won       Boolean
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Meilleur score d'un utilisateur pour un jeu donné (un enregistrement par
/// couple utilisateur/jeu — upsert quand un nouveau record est battu).
model Score {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String
  best      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, gameId])
  @@index([gameId, best])
}

// ──────────────────────────────────────────────────────────────────────────
// Contenu du jeu (anciennement dans data/). Source de vérité = la base ;
// les fichiers data/ ne servent plus qu'au typage et au seed initial.
// ──────────────────────────────────────────────────────────────────────────

/// Catégorie de stats du builder ("Build the Perfect Sorcerer").
/// `id` = CategoryId (ex. "innate-technique").
model Category {
  id          String @id
  label       String
  description String
  weight      Float
  drawCount   Int
  position    Int    @default(0)
}

/// Personnage du roster. `ratings` est un objet JSON
/// { [categoryId]: note 0-100 } — la présence d'une clé = éligible à la catégorie.
model Character {
  id        String  @id
  name      String
  title     String
  tier      String
  /// URL d'affichage : chemin statique (/assets/...) OU route API d'une image uploadée.
  image     String?
  /// Image uploadée via /admin (binaire en base, servie par /api/characters/[id]/image).
  imageData Bytes?
  imageMime String?
  ratings   Json
  /// Score de combat pour le jeu "JJK Random Battle" (cumul de fin de partie).
  /// Optionnel : le builder l'ignore ; fallback 30 côté battle si null.
  battleValue Int?
  position  Int     @default(0)

  // ── Attributs JJKdle (remplis via /admin, non seedés). Nullable = "non renseigné".
  // Un personnage n'entre dans le pool quotidien que si TOUS ces champs sont remplis.
  race          JjkRace?
  gender        JjkGender?
  grade         JjkGrade?
  affiliation   JjkAffiliation?
  clan          JjkClan? // NONE = pas de clan (≠ null = non renseigné)
  appearanceArc JjkArc?
  hasDomain     Boolean? // nullable pour distinguer "non" (false) de "non renseigné" (null)
  /// Énergie occulte "lore" (indice numérique ↑/↓). DÉDUPLIQUÉE VOLONTAIREMENT de la
  /// note builder ratings["cursed-energy"] (échelle gameplay 0–100) : la valeur lore
  /// peut différer et ne doit pas coupler JJKdle au barème du builder.
  cursedEnergy  Int?

  /// Utilisateurs ayant choisi ce personnage comme avatar de profil.
  avatarUsers User[] @relation("UserAvatar")

  @@index([position])
}

/// Personnage du jeu "Jujutsu Draft" (roster propre, éditable depuis /admin).
/// `excellenceCategory` et `tier` sont des chaînes validées côté action.
model DraftCharacter {
  id                 String  @id
  name               String
  /// URL d'affichage : chemin statique (/assets/...) OU route API d'une image uploadée.
  image              String?
  /// Image uploadée via /admin (binaire en base, servie par /api/draft-characters/[id]/image).
  imageData          Bytes?
  imageMime          String?
  excellenceCategory String
  tier               String
  cost               Int
  statValue          Int
  position           Int     @default(0)

  @@index([position])
}

/// Consigne du jeu "JJK Pyramid" : `order` = 8 IDs de personnages, rang 1→8.
/// `pool` = thème/casting (axe « qui »), `category` = critère (axe « selon quoi »).
model RankingCondition {
  id       String   @id
  pool     String   @default("")
  category String
  prompt   String
  order    String[]
  position Int      @default(0)

  @@index([position])
}

// ──────────────────────────────────────────────────────────────────────────
// Multijoueur — lobbys privés (builder uniquement pour l'instant).
//
// Le serveur est autoritatif : l'état de chaque partie vit ici, les Server
// Actions le mutent puis déclenchent un événement Pusher rebroadcasté au lobby.
// ──────────────────────────────────────────────────────────────────────────

/// Cycle de vie d'un lobby.
enum LobbyStatus {
  WAITING // salon d'attente, on peut encore rejoindre
  PLAYING // partie en cours (synchronisation lockstep par manche)
  FINISHED // partie terminée, récap affiché
}

/// Lobby privé (partie multijoueur). `code` = code court partageable.
model Lobby {
  id         String      @id @default(cuid())
  code       String      @unique
  gameId     String      @default("builder")
  hostId     String
  status     LobbyStatus @default(WAITING)
  /// Manche courante (0-indexée) : nombre de catégories déjà verrouillées par joueur.
  roundIndex Int         @default(0)
  /// État de jeu autoritatif pour les modes hors builder (ex. "JJK Random Battle").
  /// Blob JSON spécifique au gameId ; vide ({}) pour le builder.
  gameState  Json        @default("{}")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  players LobbyPlayer[]

  @@index([code])
}

/// Plateau d'un joueur dans un lobby (sa sélection verrouillée + son tirage courant).
model LobbyPlayer {
  id              String  @id @default(cuid())
  lobbyId         String
  lobby           Lobby   @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  userId          String
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Ordre d'arrivée (l'hôte = 0) — sert au tri d'affichage.
  joinOrder       Int
  /// Sélection verrouillée : { [categoryId]: characterId }.
  selection       Json    @default("{}")
  /// Tirage courant proposé à ce joueur : { [categoryId]: characterId | null }.
  currentDraw     Json    @default("{}")
  /// A verrouillé une catégorie pour la manche en cours (lockstep).
  lockedThisRound Boolean @default(false)
  /// Score final (calculé à la fin via evaluateBuild).
  finalScore      Int?

  @@unique([lobbyId, userId])
  @@index([lobbyId])
}
